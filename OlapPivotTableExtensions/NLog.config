<?xml version="1.0" encoding="utf-8" ?>
<nlog xmlns="http://www.nlog-project.org/schemas/NLog.xsd"
      xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
      autoReload="true"
      internalLogLevel="Warn"
      internalLogFile="${specialfolder:folder=LocalApplicationData}/OlapPivotTableExtensions/logs/nlog-internal.log">

  <targets>
    <target name="file" xsi:type="File"
            fileName="${specialfolder:folder=LocalApplicationData}/OlapPivotTableExtensions/logs/olap-ext.log"
            archiveEvery="Day"
            maxArchiveFiles="7"
            layout="${longdate}|${level:uppercase=true}|${logger:shortName=true}|${message}${onexception:${newline}${exception:format=ToString}}" />
  </targets>

  <rules>
    <logger name="*" minlevel="Info" writeTo="file" />
  </rules>

</nlog>
